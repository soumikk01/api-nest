<?xml version="1.0" encoding="UTF-8"?>
<!-- This pom.xml exists only to give the IDE a classpath for ApiMonitorFilter.java.
     It is NOT meant to be built — this folder contains template files only. -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.3.5</version>
    <relativePath/>
  </parent>

  <groupId>com.apinest</groupId>
  <artifactId>agent-templates</artifactId>
  <version>1.0.0</version>
  <name>APINest Agent Templates (IDE only — not for building)</name>

  <properties>
    <java.version>21</java.version>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
  </dependencies>
</project>
