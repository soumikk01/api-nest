generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
//  USER  (BetterAuth-compatible)
// ──────────────────────────────────────────────
model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  emailVerified  Boolean  @default(false)   // required by BetterAuth
  password       String?                    // nullable — OAuth users have no password
  name           String?
  image          String?                    // avatar URL from OAuth providers
  avatar         Int      @default(0)       // legacy numeric avatar selector
  geminiApiKey   String?  // per-user Gemini API key (encrypted at rest by MongoDB)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Required by BetterAuth twoFactor plugin
  twoFactorEnabled Boolean @default(false)

  // BetterAuth relations
  sessions        Session[]
  accounts        Account[]
  twoFactors      TwoFactor[]

  // App relations
  projects        Project[]
  projectMembers  ProjectMember[]
  apiCalls        ApiCall[]
  alertRules      AlertRule[]
  auditLogs       AuditLog[]
  aiConversations AiConversation[]
}

// ──────────────────────────────────────────────
//  SESSION  (BetterAuth managed)
// ──────────────────────────────────────────────
model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────
//  ACCOUNT  (OAuth provider links per user)
// ──────────────────────────────────────────────
model Account {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  accountId             String    // provider's user ID (sub)
  providerId            String    // "google" | "github" | "credential"
  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   // hashed password for credential provider
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
}

// ──────────────────────────────────────────────
//  VERIFICATION  (email verify / reset tokens)
// ──────────────────────────────────────────────
model Verification {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  identifier String    // email address
  value      String    // the token/OTP value
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([identifier])
}

// ──────────────────────────────────────────────
//  TWO FACTOR  (BetterAuth twoFactor plugin)
//  Required by the twoFactor plugin — stores
//  TOTP secrets and backup codes per user.
// ──────────────────────────────────────────────
model TwoFactor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  secret      String   // TOTP secret (encrypted)
  backupCodes String   // comma-separated one-time backup codes
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // BetterAuth 1.6.9 twoFactor plugin sends this field on create
  verified    Boolean  @default(false)
}


// ──────────────────────────────────────────────
//  PROJECT
// ──────────────────────────────────────────────
model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  slug        String?  // URL-safe identifier derived from name
  serviceMode String   @default("single") // "single" | "multi"
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiCalls     ApiCall[]
  environments Environment[]
  alertRules   AlertRule[]
  auditLogs    AuditLog[]
  members      ProjectMember[]
  services     Service[]

  @@index([userId])
}

// ──────────────────────────────────────────────
//  PROJECT MEMBER (Multi-user access)
// ──────────────────────────────────────────────
model ProjectMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // "OWNER" | "ADMIN" | "MEMBER"
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

// ──────────────────────────────────────────────
//  SERVICE  (logical grouping within a project)
// ──────────────────────────────────────────────
model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isDefault   Boolean  @default(false)  // true for the auto-created single-service
  sdkToken    String?  @unique          // per-service SDK credential (required after backfill)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apiCalls    ApiCall[]

  @@index([projectId])
  @@unique([projectId, name])
}

// ──────────────────────────────────────────────
//  ENVIRONMENT  (production / staging / dev / custom)
// ──────────────────────────────────────────────
model Environment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String                        // e.g. "production"
  label     String                        // display label, e.g. "Production"
  color     String   @default("#10b981") // hex, shown in UI badge
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  apiCalls ApiCall[]

  @@index([projectId])
}

// ──────────────────────────────────────────────
//  API CALL  (one record per intercepted request)
// ──────────────────────────────────────────────
model ApiCall {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String       @db.ObjectId
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId     String?      @db.ObjectId   // which service generated this call
  service       Service?     @relation(fields: [serviceId], references: [id])
  userId        String       @db.ObjectId
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  environmentId String?      @db.ObjectId
  environment   Environment? @relation(fields: [environmentId], references: [id])

  // Request
  method         String
  url            String
  host           String
  path           String
  requestHeaders Json?
  requestBody    Json?
  queryParams    Json?

  // Response
  statusCode      Int?
  statusText      String?
  responseHeaders Json?
  responseBody    Json?
  responseSize    Int?     // bytes

  // Timing
  latency   Int      // milliseconds
  startedAt DateTime
  endedAt   DateTime

  // Classification
  // SUCCESS | CLIENT_ERROR | SERVER_ERROR | TIMEOUT | PENDING
  status String @default("PENDING")

  // SDK / CLI metadata
  sdkVersion String? // version of the CLI that sent this event
  hostname   String? // machine hostname, helps debug multi-instance setups

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([serviceId])                  // per-service queries
  @@index([serviceId, createdAt])       // service time-range queries
  @@index([serviceId, status])          // service error-rate queries
  @@index([projectId, status])          // fast error-rate queries
  @@index([projectId, createdAt])       // fast time-range queries
  @@index([host])                       // fast per-host analytics
}

// ──────────────────────────────────────────────
//  ALERT RULE  (user-defined threshold alerts)
// ──────────────────────────────────────────────
// Example: "Alert me if error rate > 5% in 5 min window"
model AlertRule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  metric    String   // "error_rate" | "latency_p95" | "total_calls"
  operator  String   // "gt" | "lt" | "gte" | "lte"
  threshold Float    // the value to compare against
  windowMin Int      @default(5)  // rolling window in minutes
  enabled   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

// ──────────────────────────────────────────────
//  AUDIT LOG  (tracks user actions on projects)
// ──────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?  @db.ObjectId
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  action    String   // "PROJECT_CREATED" | "PROJECT_DELETED" | "TOKEN_REGENERATED" etc.
  detail    Json?    // arbitrary context (e.g. { "name": "my-api" })
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
//  AI CONVERSATION  (one thread per troubleshooting session)
// ──────────────────────────────────────────────
model AiConversation {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String?  // auto-set from first message
  context Json?    // { endpoint, method, statusCode, errorMessage, latency, timestamp }

  messages  AiMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
}

// ──────────────────────────────────────────────
//  AI MESSAGE  (individual turn in a conversation)
// ──────────────────────────────────────────────
model AiMessage {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String         @db.ObjectId
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String  // "user" | "assistant"
  content String

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// ──────────────────────────────────────────────
//  PLATFORM CONFIG
//  Global key-value store for admin-managed
//  platform settings (e.g. Gemini API key).
// ──────────────────────────────────────────────
model PlatformConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique   // e.g. "gemini_api_key"
  value     String             // encrypted / sensitive value
  updatedAt DateTime @updatedAt
  updatedBy String?            // userId of last admin who changed it
}
