{
  "name": "@api-monitor/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build":             "prisma generate && nest build",
    "build:clean":       "node -e \"const fs=require('fs');const path=require('path');const walk=(d)=>{if(!fs.existsSync(d))return;for(const f of fs.readdirSync(d)){const p=path.join(d,f);if(fs.statSync(p).isDirectory())walk(p);else if(!p.endsWith('.dll.node'))fs.rmSync(p);}}; walk('./dist');\" && prisma generate && nest build",
    "format":            "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",

    "dev":               "node -e \"const fs=require('fs');const src='src/generated/prisma';const dst='dist/generated/prisma';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.node')){try{fs.copyFileSync(src+'/'+f,dst+'/'+f);console.log('[prisma] copied',f)}catch(e){console.warn('[prisma] copy warn:',e.message)}}}\" && nest start --watch",
    "dev:worker":        "node -e \"const fs=require('fs');const src='src/generated/prisma';const dst='dist/generated/prisma';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.node')){try{fs.copyFileSync(src+'/'+f,dst+'/'+f)}catch{}}}\" && nest build && bun run dist/worker",

    "start":             "nest start",
    "start:dev":         "node -e \"const fs=require('fs');const src='src/generated/prisma';const dst='dist/generated/prisma';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){if(f.endsWith('.node')){try{fs.copyFileSync(src+'/'+f,dst+'/'+f)}catch{}}}\" && nest start --watch",
    "start:debug":       "nest start --debug --watch",

    "start:prod":        "node dist/main",
    "start:prod:bun":    "bun run dist/main",

    "start:prod2":       "PORT=4001 node dist/main",
    "start:prod2:bun":   "PORT=4001 bun run dist/main",

    "worker:prod":       "node dist/worker",
    "worker:bun":        "bun run dist/worker",

    "lint":              "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test":              "jest",
    "test:watch":        "jest --watch",
    "test:cov":          "jest --coverage",
    "test:debug":        "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e":          "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^6",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/ioredis": "^5.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
