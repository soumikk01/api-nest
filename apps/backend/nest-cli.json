{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      {
        "include": "generated/prisma/**/*.js",
        "outDir": "./dist",
        "watchAssets": false
      },
      {
        "include": "generated/prisma/**/*.d.ts",
        "outDir": "./dist",
        "watchAssets": false
      },
      {
        "include": "generated/prisma/**/*.json",
        "outDir": "./dist",
        "watchAssets": false
      }
    ]
  }
}

