# ─── Apio Backend — Environment Variables ────────────────────────────────────
# Copy this file to .env for local development.
# For Railway: add these in your service's Variables tab.

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/apio?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis URL (use rediss:// for TLS — required by Upstash)
REDIS_URL=rediss://default:PASSWORD@global-xxxxx.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_REFRESH_SECRET=your_different_64_char_hex_secret_here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS — set to your real Vercel URLs ───────────────────────────────────────
FRONTEND_URL=https://your-apio-web.vercel.app
AUTH_URL=https://your-apio-auth.vercel.app
