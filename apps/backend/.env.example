# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Use M10+ dedicated cluster for 10k users.
# PrismaService appends maxPoolSize=20&minPoolSize=5 automatically.
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/api_monitor

# ── Redis (Managed — Upstash or Redis Cloud) ──────────────────────────────────
# Use a managed Redis service — no Redis container needed.
#
# Upstash (free tier, serverless):
#   https://console.upstash.com → Create Database → copy "REDIS_URL"
#   Format: rediss://:<password>@<host>:<port>
#
# Redis Cloud (free 30MB):
#   https://redis.com/try-free → copy endpoint + password
#   Format: redis://:<password>@<host>:<port>
#
# The app auto-detects rediss:// and enables TLS.
REDIS_URL=rediss://:your-password@your-host.upstash.io:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-different-from-above
# Token lifetimes — access token is short-lived, refresh is long-lived
# Supabase uses 1h/7d; we use 1h/30d for a better "stay logged in" UX
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
