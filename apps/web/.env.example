# ─── Apio Web App — Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local development.
# For Vercel: add these in Project Settings → Environment Variables.

# Backend API URL (no trailing slash)
# Local:      http://localhost:4000/api/v1
# Production: https://your-railway-backend.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# WebSocket URL (no path — the /ws namespace is appended in code)
# Local:      http://localhost:4000
# Production: https://your-railway-backend.up.railway.app
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Auth app URL (login / register pages)
# Local:      http://localhost:3001
# Production: https://your-apio-auth.vercel.app
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
