# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
out/

# production
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.sample

# IDE and editors
.idea/
.vscode/
*.swp
*.swo

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generation scripts
app/gen2.js
app/html-to-jsx.js
app/landing-gen.js
app/theme-gen.js

# API Nest configuration
.api-nest.json

# prisma generated artifacts (avoid polluting git history)
**/src/generated/prisma

# Turborepo
.turbo/

# Legacy backend/ dist only — new language samples are tracked
!backend/java-sample/
!backend/python-sample/
!backend/go-sample/
backend/dist/
