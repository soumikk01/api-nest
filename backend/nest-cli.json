{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      {
        "include": "generated/prisma/*.dll.node",
        "outDir": "./dist",
        "watchAssets": false
      },
      {
        "include": "generated/prisma/*.so.node",
        "outDir": "./dist",
        "watchAssets": false
      }
    ]
  }
}
